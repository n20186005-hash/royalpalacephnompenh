---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, buildAlternates, htmlLangAttr, getI18n } from '../i18n/ui';
import { ogLocale, siteConfig } from '../config';
import { poi } from '../data/poi';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const htmlLang = htmlLangAttr(lang);
const alts = buildAlternates(path);
const canonical = alts[lang] ?? alts.xDefault;
const { messages } = getI18n(Astro.url);
const attractionName = messages.header?.siteName ?? poi.name[lang] ?? poi.name.en;
const localName = poi.name[lang] ?? poi.name.en;
const localOpening = poi.opening[lang] ?? poi.opening.en;
const localCategory = poi.category[lang] ?? poi.category.en;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: localName,
  alternateName: poi.alternateName[lang] ?? poi.alternateName.en,
  description: description,
  url: canonical,
  image: siteConfig.baseUrl + poi.heroImage,
  address: {
    '@type': 'PostalAddress',
    streetAddress: poi.address,
    addressLocality: poi.city,
    addressRegion: poi.region,
    addressCountry: poi.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: poi.lat,
    longitude: poi.lng,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  isAccessibleForFree: true,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: String(poi.rating),
    reviewCount: String(poi.reviews),
  },
  sameAs: [poi.mapsUrl],
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: messages.header.home, item: `${siteConfig.baseUrl}/${lang}` },
    { '@type': 'ListItem', position: 2, name: messages.about.title, item: `${siteConfig.baseUrl}/${lang}#about` },
    { '@type': 'ListItem', position: 3, name: messages.transport.title, item: `${siteConfig.baseUrl}/${lang}#transport` },
    { '@type': 'ListItem', position: 4, name: attractionName, item: canonical },
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="km" href={alts.km} />
    <link rel="alternate" hreflang="en" href={alts.en} />
    <link rel="alternate" hreflang="zh" href={alts.zh} />
    <link rel="alternate" hreflang="x-default" href={alts.xDefault} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale[lang] ?? lang} />
    <meta property="og:image" content={siteConfig.baseUrl + poi.heroImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={siteConfig.baseUrl + poi.heroImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)}></script>

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white text-slate-900" style="background: var(--bg-primary); color: var(--text-primary);">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
