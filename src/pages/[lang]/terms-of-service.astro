---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalLayout from '../../components/LegalLayout.astro';
import { getI18n, languagesList } from '../../i18n/ui';

export function getStaticPaths() {
  return languagesList.map((lang) => ({ params: { lang } }));
}

const { lang, messages } = getI18n(Astro.url);
const title = messages.legal.termsTitle;
const meta = messages.footer?.siteName ?? messages.header?.siteName ?? '';
---

<BaseLayout
  title={`${title} · ${meta}`}
  description={messages.legal.terms.accessText}
>
  <LegalLayout kind="terms" />
</BaseLayout>
