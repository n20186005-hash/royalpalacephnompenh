---
import { resolveBaseUrl } from '../config';
const target = '/km';
const siteUrl = resolveBaseUrl();
---

<!doctype html>
<html lang="km">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={`${siteUrl}/km`} />
    <title>Royal Palace of Cambodia · ព្រះបរមរាជវាំង</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>ខ្មែរ</a>…</p>
  </body>
</html>
