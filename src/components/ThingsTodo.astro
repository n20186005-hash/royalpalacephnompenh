---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const s = messages.thingsTodo;
const items = s.items ?? [];
const route = s.oldTownRoute ?? {};
const steps = route.steps ?? [];
---

<section id="visit" class="section-shell-alt">
  <div class="max-w-6xl mx-auto px-4 py-16 sm:py-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--text-primary);">{s.title}</h2>
      {s.intro && <p class="mt-3 max-w-2xl mx-auto text-base sm:text-lg" style="color: var(--text-secondary);">{s.intro}</p>}
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((it) => (
        <div class="rounded-2xl p-6 flex flex-col" style="background: var(--card-bg); border: 1px solid var(--border-color);">
          <span class="text-3xl mb-3" aria-hidden="true">{it.icon}</span>
          <h3 class="font-semibold text-lg mb-2" style="color: var(--text-primary);">{it.title}</h3>
          <p class="text-sm flex-1" style="color: var(--text-secondary);">{it.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {(it.tags ?? []).map((tag) => (
              <span class="text-xs px-2.5 py-1 rounded-full" style="background: var(--color-ocean-50, #f0f9ff); color: var(--color-ocean-700, #075985);">{tag}</span>
            ))}
          </div>
          {it.duration && (
            <p class="mt-3 text-xs" style="color: var(--text-muted);">⏱ {it.duration}</p>
          )}
        </div>
      ))}
    </div>

    {steps.length > 0 && (
      <div class="mt-12 rounded-2xl p-6 sm:p-8" style="background: var(--card-bg); border: 1px solid var(--border-color);">
        <h3 class="font-semibold text-lg mb-5" style="color: var(--text-primary);">{route.title}</h3>
        <ol class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          {steps.map((step, i) => (
            <li class="flex items-center gap-3">
              <span class="flex items-center justify-center w-8 h-8 rounded-full text-sm font-semibold shrink-0" style="background: var(--color-ocean-600, #0369a1); color: #fff;">{i + 1}</span>
              <span class="text-sm font-medium" style="color: var(--text-primary);">{step}</span>
              {i < steps.length - 1 && <span class="ml-1 text-lg" style="color: var(--text-muted);" aria-hidden="true">→</span>}
            </li>
          ))}
        </ol>
      </div>
    )}
  </div>
</section>
