---
import { getI18n } from '../i18n/ui';
import { poi } from '../data/poi';

const { lang, messages } = getI18n(Astro.url);
const h = messages.hero;
const facts = h.quickFacts ?? [];
const mapsUrl = messages.mapsUrl ?? poi.mapsUrl;
---

<section id="overview" class="relative min-h-[84vh] sm:min-h-[88vh] flex items-center justify-center text-center overflow-hidden">
  <div class="absolute inset-0" style={`background-image: linear-gradient(rgba(8,47,73,0.55), rgba(8,47,73,0.62)), url('${poi.heroImage}'); background-size: cover; background-position: center;`}></div>
  <div class="relative z-10 px-4 sm:px-6 py-16 sm:py-20 max-w-4xl w-full animate-fade-in-up">
    <span class="inline-flex max-w-full flex-wrap items-center justify-center gap-1 px-3 py-1 mb-5 rounded-full text-xs sm:text-sm font-medium" style="background: rgba(255,255,255,0.15); color: #fff; backdrop-filter: blur(4px);">
      ⭐ {poi.rating} · {poi.reviews.toLocaleString(lang === 'pt' ? 'pt-PT' : lang === 'zh' ? 'zh-CN' : 'en-US')} reviews
    </span>

    <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-4">
      {h.title}
    </h1>

    <p class="text-sm sm:text-lg text-white/90 mb-7 max-w-2xl mx-auto leading-relaxed">
      {h.subtitle}
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-2xl mx-auto mb-8">
      {facts.map((f) => (
        <div class="rounded-2xl px-3 py-3" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(8px);">
          <span class="block text-xl mb-1" aria-hidden="true">{f.icon}</span>
          <span class="block text-[11px] uppercase tracking-wide text-white/70">{f.label}</span>
          <span class="block text-sm font-semibold text-white">{f.value}</span>
        </div>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="btn-cta btn-cta-primary">
        🗺️ {h.ctaMaps}
      </a>
    </div>
  </div>
</section>
