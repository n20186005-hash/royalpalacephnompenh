---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const b = messages.bestTime;
const seasons = b.seasons ?? [];
---

<section id="best-time" class="section-shell-alt">
  <div class="max-w-5xl mx-auto px-4 py-16 sm:py-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--text-primary);">{b.title}</h2>
      {b.intro && <p class="mt-3 max-w-2xl mx-auto text-base sm:text-lg" style="color: var(--text-secondary);">{b.intro}</p>}
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {seasons.map((s) => (
        <div class="rounded-2xl p-5" style="background: var(--card-bg); border: 1px solid var(--border-color);">
          <span class="text-2xl mb-2 block" aria-hidden="true">🌤️</span>
          <h3 class="font-semibold text-base mb-2" style="color: var(--text-primary);">{s.period}</h3>
          <p class="text-sm" style="color: var(--text-secondary);">{s.note}</p>
        </div>
      ))}
    </div>
  </div>
</section>
