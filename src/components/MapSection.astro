---
import { getI18n } from '../i18n/ui';
import { poi } from '../data/poi';

const { lang, messages } = getI18n(Astro.url);
const mapsUrl = messages.mapsUrl ?? poi.mapsUrl;
const h = messages.header;
---

<section id="map" class="section-shell-alt">
  <div class="max-w-6xl mx-auto px-4 py-16 sm:py-20">
    <div class="text-center mb-8">
      <h2 class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--text-primary);">{h.map}</h2>
      <p class="mt-3 text-sm" style="color: var(--text-secondary);">{poi.address}</p>
    </div>

    <div class="rounded-2xl overflow-hidden border" style="border-color: var(--border-color);">
      <iframe
        title="Royal Palace of Cambodia map"
        class="w-full h-[420px]"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src={`https://www.openstreetmap.org/export/embed.html?bbox=${poi.lng - 0.004}%2C${poi.lat - 0.003}%2C${poi.lng + 0.004}%2C${poi.lat + 0.003}&layer=mapnik&marker=${poi.lat}%2C${poi.lng}`}>
      </iframe>
    </div>

    <div class="mt-6 text-center">
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="btn-cta btn-cta-primary">
        🗺️ {messages.hero.ctaMaps}
      </a>
    </div>
  </div>
</section>
