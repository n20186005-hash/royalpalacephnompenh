---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const f = messages.faq;
const items = f.items ?? [];
---

<section id="faq" class="section-shell">
  <div class="max-w-3xl mx-auto px-4 py-16 sm:py-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--text-primary);">{f.title}</h2>
    </div>

    <div class="space-y-3">
      {items.map((it) => (
        <details class="rounded-2xl p-5" style="background: var(--card-bg); border: 1px solid var(--border-color);">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between" style="color: var(--text-primary);">
            <span>{it.q}</span>
            <span class="text-lg" style="color: var(--text-muted);" aria-hidden="true">+</span>
          </summary>
          <p class="mt-3 text-sm" style="color: var(--text-secondary);">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
