---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const a = messages.about;
const paragraphs = a.paragraphs ?? [];
---

<section id="about" class="section-shell">
  <div class="max-w-3xl mx-auto px-4 py-16 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] mb-3" style="color: var(--color-ocean-600, #0369a1);">Phnom Penh · Cambodia</p>
    <h2 class="font-display text-3xl sm:text-4xl font-bold mb-6" style="color: var(--text-primary);">{a.title}</h2>
    <div class="space-y-4 text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">
      {paragraphs.map((p) => (
        <p>{p}</p>
      ))}
    </div>
  </div>
</section>
