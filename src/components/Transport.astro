---
import { getI18n } from '../i18n/ui';
import { poi } from '../data/poi';

const { lang, messages } = getI18n(Astro.url);
const t = messages.transport ?? {};
const mapsUrl = messages.mapsUrl ?? poi.mapsUrl;
const modes = t.modes ?? [];
---

<section id="transport" class="section-shell">
  <div class="max-w-5xl mx-auto px-4 py-16 sm:py-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--text-primary);">{t.title}</h2>
      {t.intro && <p class="mt-3 max-w-2xl mx-auto text-base sm:text-lg" style="color: var(--text-secondary);">{t.intro}</p>}
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {modes.map((m) => (
        <div class="rounded-2xl p-6" style="background: var(--card-bg); border: 1px solid var(--border-color);">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl" aria-hidden="true">{m.icon ?? '🚏'}</span>
            <h3 class="font-semibold text-lg" style="color: var(--text-primary);">{m.name}</h3>
          </div>
          <p class="text-sm" style="color: var(--text-secondary);">{m.desc}</p>
        </div>
      ))}
    </div>

    {t.steps && t.steps.length > 0 && (
      <div class="card p-6 sm:p-8 max-w-3xl mx-auto mt-10">
        <h3 class="font-bold text-lg mb-4" style="color: var(--text-primary);">{t.stepsTitle ?? 'Step-by-step'}</h3>
        <div class="space-y-4">
          {t.steps.map((s) => (
            <div class="flex gap-3">
              <div class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold" style="background: var(--accent-bg); color: var(--accent-text);">{s.n}</div>
              <div>
                <p class="font-medium text-sm" style="color: var(--text-primary);">{s.title}</p>
                {s.detail && <p class="text-sm mt-0.5" style="color: var(--text-secondary);">{s.detail}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="text-center mt-8">
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="btn-cta btn-cta-primary">
        🗺️ {t.mapCta ?? 'Open in Maps'}
      </a>
    </div>
  </div>
</section>
