---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const f = messages.food;
const dishes = f.dishes ?? [];
---

<section id="food" class="section-shell">
  <div class="max-w-5xl mx-auto px-4 py-16 sm:py-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--text-primary);">{f.title}</h2>
      {f.intro && <p class="mt-3 max-w-2xl mx-auto text-base sm:text-lg" style="color: var(--text-secondary);">{f.intro}</p>}
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {dishes.map((d) => (
        <div class="rounded-2xl p-6" style="background: var(--card-bg); border: 1px solid var(--border-color);">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl" aria-hidden="true">🍽️</span>
            <h3 class="font-semibold text-lg" style="color: var(--text-primary);">{d.name}</h3>
          </div>
          <p class="text-sm" style="color: var(--text-secondary);">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
