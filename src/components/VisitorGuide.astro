---
const { messages } = Astro.props;
const v = messages.visitorGuide;
---

<section class="section-padding bg-soft section-divider" id="visit">
  <div class="container-page">
    <p class="section-eyebrow">Plan your trip</p>
    <h2 class="section-title">{v.title}</h2>

    <div class="mt-8 grid gap-5 lg:grid-cols-3">
      <div class="card p-6">
        <div class="text-3xl">🕗</div>
        <h3 class="mt-3 font-bold text-[color:var(--color-text)]">{v.hoursTitle}</h3>
        <p class="mt-1 text-[color:var(--color-muted)]">{v.hoursValue}</p>
      </div>
      <div class="card p-6">
        <div class="text-3xl">⏱️</div>
        <h3 class="mt-3 font-bold text-[color:var(--color-text)]">{v.durationTitle}</h3>
        <p class="mt-1 text-[color:var(--color-muted)]">{v.durationValue}</p>
        <p class="mt-2 text-sm text-[color:var(--color-muted)]">{v.durationNote}</p>
      </div>
      <div class="card p-6">
        <div class="text-3xl">💡</div>
        <h3 class="mt-3 font-bold text-[color:var(--color-text)]">{v.tipsTitle}</h3>
        <ul class="mt-2 space-y-1.5 text-sm text-[color:var(--color-muted)] list-disc pl-4">
          {v.tips.map((tip) => <li>{tip}</li>)}
        </ul>
      </div>
    </div>

    {v.route && v.route.length > 0 && (
      <div class="mt-8 card p-6 sm:p-8 max-w-3xl mx-auto">
        <h3 class="font-bold text-lg" style="color: var(--color-text);">{v.routeTitle}</h3>
        <ol class="mt-3 space-y-2 list-decimal pl-5 text-sm" style="color: var(--color-muted);">
          {v.route.map((step) => <li>{step}</li>)}
        </ol>
      </div>
    )}
  </div>
</section>
