---
const { messages } = Astro.props;
const d = messages.dressCode;
---

<section class="section-padding bg-soft section-divider" id="dress">
  <div class="container-page">
    <p class="section-eyebrow">Etiquette</p>
    <h2 class="section-title">{d.title}</h2>
    {d.intro && <p class="section-intro">{d.intro}</p>}

    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {d.items.map((it) => (
        <div class="card p-6 text-center">
          <div class="text-4xl">{it.icon}</div>
          <h3 class="mt-3 font-bold text-[color:var(--color-text)]">{it.title}</h3>
          <p class="mt-2 text-sm text-[color:var(--color-muted)] leading-relaxed">{it.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
