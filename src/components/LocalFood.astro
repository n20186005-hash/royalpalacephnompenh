---
const { messages } = Astro.props;
const f = messages.food;
---

<section class="section-padding bg-soft section-divider" id="food">
  <div class="container-page">
    <p class="section-eyebrow">Taste the place</p>
    <h2 class="section-title">{f.title}</h2>
    {f.intro && <p class="section-intro">{f.intro}</p>}

    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {f.items.map((it) => (
        <article class="card p-6">
          <div class="text-3xl">🍜</div>
          <h3 class="mt-3 font-bold text-[color:var(--color-text)]">{it.name}</h3>
          <p class="mt-2 text-sm text-[color:var(--color-muted)] leading-relaxed">{it.desc}</p>
          {it.dishes && (
            <ul class="mt-3 flex flex-wrap gap-2">
              {it.dishes.map((dish) => <li class="chip">{dish}</li>)}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
