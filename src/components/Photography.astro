---
const { messages } = Astro.props;
const p = messages.photography;
---

<section class="section-padding bg-soft section-divider" id="photography">
  <div class="container-page">
    <p class="section-eyebrow">For photographers</p>
    <h2 class="section-title">{p.title}</h2>
    {p.intro && <p class="section-intro">{p.intro}</p>}

    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      <div class="card p-6">
        <h3 class="font-bold text-[color:var(--color-text)]">{p.timesTitle}</h3>
        <ul class="mt-3 space-y-3">
          {p.times.map((t) => (
            <li>
              <p class="font-semibold text-[color:var(--color-red-700)]">{t.name}</p>
              <p class="text-sm text-[color:var(--color-muted)]">{t.desc}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="card p-6">
        <h3 class="font-bold text-[color:var(--color-text)]">{p.spotsTitle}</h3>
        <ul class="mt-3 space-y-2">
          {p.spots.map((s) => (
            <li class="flex gap-2 text-[color:var(--color-muted)]"><span class="star">📸</span><span>{s}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
